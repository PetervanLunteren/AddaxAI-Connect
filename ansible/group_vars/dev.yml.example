---
# ============================================================
# Settings you need to configure
# ============================================================

# Passwords and secrets — generate with: openssl rand -hex 32
app_user_password: "PASSWORD"                                       # Password for sudo access on the server
ftps_password: "changeme_ftps123"                                   # Password for FTPS camera uploads
db_password: "changeme_db123"                                       # Database password
minio_password: "changeme_minio123"                                 # MinIO storage admin password
redis_password: "changeme_redis123"                                 # Redis password
jwt_secret: "changeme_jwt_secret_very_long_random_string_123"       # Secret key for signing JWT tokens
monitoring_password: "changeme_monitoring123"                        # Password for monitoring tools

# Classification model
classification_model: ""                  # "deepfaune" (38 European species) or "speciesnet" (2,498 global species)

# Domain and TLS
domain_name: ""                           # Your domain (e.g. "cam.example.com")
letsencrypt_email: ""                     # Email for SSL certificate registration
letsencrypt_staging: false                # false = real certificates, true = test certificates (use during testing to avoid rate limits)

# Email
mail_server: ""                           # SMTP server (e.g. "smtp.gmail.com")
mail_port: 587                            # SMTP port (587 is standard for TLS)
mail_username: ""                         # SMTP username, also used as the "From" address unless mail_from is set
mail_password: ""                         # SMTP password or app password

# Initial server admin account
admin_email: ""                           # Email for the first user account (gets server admin access)

# Cold storage tier (S3-compatible). Leave cold_tier_enabled false to keep everything on local disk.
# When enabled, a daily watchdog tags the oldest raw-images for transition once local disk usage
# exceeds cold_tier_hot_budget_gb; a MinIO ILM rule moves tagged objects to the cold bucket.
# Reads stay transparent. Thumbnails, crops, and project assets always stay hot.
cold_tier_enabled: false                  # true to enable the cold tier
cold_tier_endpoint: ""                    # e.g. "https://s3.eu-central-1.wasabisys.com" (Wasabi Amsterdam)
cold_tier_bucket: ""                      # Bucket name in the cold provider
cold_tier_region: "eu-central-1"          # Region of the cold bucket (Wasabi Amsterdam)
cold_tier_access_key: ""                  # Cold-tier access key
cold_tier_secret_key: ""                  # Cold-tier secret key
cold_tier_hot_budget_gb: 80               # GB of raw-images to keep on-disk; the watchdog tiers the excess

# Disk usage alert thresholds (comma-separated percentages). Server admins receive
# a one-shot email when the root filesystem crosses any of these. A drop below a
# level re-arms it so the next crossing sends a fresh alert.
disk_alert_thresholds: "80,90,95"

# Automated daily backups to a Wasabi bucket (02:00 UTC). Leave backup_enabled
# false to skip. When enabled, scripts/backup.sh dumps postgres + mirrors every
# authoritative MinIO bucket and host image dir into backup_bucket under a
# path prefixed by the server's domain_name. Retention is set by a Wasabi
# lifecycle rule (see docs/operations.md), not by this script.
backup_enabled: false                     # true to enable the daily cron
backup_endpoint: ""                       # e.g. "https://s3.eu-central-1.wasabisys.com" (Wasabi Amsterdam)
backup_bucket: ""                         # Dedicated backup bucket (separate from the cold-tier bucket)
backup_region: "eu-central-1"             # Region of the backup bucket
backup_access_key: ""                     # Bucket-scoped IAM key
backup_secret_key: ""                     # Bucket-scoped IAM secret

# ============================================================
# Defaults — usually fine as-is
# ============================================================

# Application
app_user: ubuntu
app_directory: /opt/addaxai-connect
app_environment: development
log_level: DEBUG

# Demo mode
demo_mode: false                          # Enable daily demo data refresh (dedicated demo servers only)

# Git
git_repo: https://github.com/PetervanLunteren/AddaxAI-Connect.git
git_branch: main

# Docker
docker_compose_version: "2.23.0"
deploy_pull_images: false

# Development tools
install_vim: true
install_htop: true
install_tree: true

# Security
enable_firewall: true
allowed_ssh_port: 22
allowed_ssh_ips:                          # IPs allowed to SSH (empty = allow all)
  # - "YOUR_IP_HERE/32"

# FTPS
ftps_username: camera
ftps_upload_dir: /opt/addaxai-connect/uploads
ftps_passive_port_min: 40000
ftps_passive_port_max: 50000

# SSL
enable_ssl: true

# Database
db_user: addaxai
db_name: addaxai_connect

# MinIO
minio_user: minioadmin

# Security verification
fail_on_security_issues: true

# ML
use_gpu: false
