---

all:
  children:
    dev:
      hosts:
        addaxai-connect:
          ansible_host: your_vm_ipv4                    # Replace with VM IPv4 (e.g., 192.168.1.100)
          ansible_user: root                            # Initial user (Ubuntu VMs typically start with root)
          ansible_ssh_private_key_file: your_ssh_key    # Path to your SSH private key (e.g., ~/.ssh/id_rsa or C:\Users\username\.ssh\id_rsa on Windows)
          ansible_python_interpreter: /usr/bin/python3
